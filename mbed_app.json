    "target_overrides": {
        "*": {
            "platform.stdio-baud-rate": 115200,
            "target.printf_lib": "std",
            "platform.minimal-printf-enable-floating-point": true,
            "target.macros_add": [
                "MBED_HEAP_STATS_ENABLED=1",
                "MBED_STACK_STATS_ENABLED=1"
            ]
        }
    }
}
